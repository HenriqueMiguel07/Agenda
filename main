import React, { useState, useEffect } from 'react';
import { Check, Plus, Trash2, AlertCircle, Clock, FileText, ChevronLeft, ChevronRight, Calendar as CalendarIcon, BookOpen, Lightbulb, Target } from 'lucide-react';

// Função auxiliar para pegar a data local no formato YYYY-MM-DD
const getLocalDateString = (date) => {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

// Gera os dias para a visualização estilo agenda (janela de 7 dias)
const generateWeekDays = (baseDateStr) => {
  const days = [];
  const [year, month, day] = baseDateStr.split('-').map(Number);
  const baseDate = new Date(year, month - 1, day);

  // Gera 3 dias antes, o dia atual, e 3 dias depois
  for (let i = -3; i <= 3; i++) {
    const d = new Date(baseDate);
    d.setDate(d.getDate() + i);
    days.push({
      dateStr: getLocalDateString(d),
      dayName: d.toLocaleDateString('pt-BR', { weekday: 'short' }).substring(0, 3).replace('.', ''),
      dayNum: d.getDate()
    });
  }
  return days;
};

// Converte strings como "14", "08", "14:30" para minutos totais do dia para ordenação precisa
const parseTimeToMinutes = (timeString) => {
  if (!timeString) return 0;
  
  const cleaned = timeString.toString().replace(/[^\d:]/g, '');
  if (!cleaned) return 0;

  let hours = 0;
  let minutes = 0;

  if (cleaned.includes(':')) {
    const parts = cleaned.split(':');
    hours = parseInt(parts[0], 10) || 0;
    minutes = parseInt(parts[1], 10) || 0;
  } else {
    hours = parseInt(cleaned, 10) || 0;
  }

  return hours * 60 + minutes;
};

// Dados iniciais baseados na sua foto
const initialBlocks = [
  {
    id: 1, startTime: '08', endTime: '12',
    tasks: [
      { id: 11, text: 'Whey', isCompleted: true, isImportant: false },
      { id: 12, text: 'Pagar as contas', isCompleted: true, isImportant: false }
    ]
  },
  {
    id: 2, startTime: '12', endTime: '14',
    tasks: [
      { id: 21, text: 'Almoço', isCompleted: true, isImportant: false },
      { id: 22, text: 'Papel CNH', isCompleted: false, isImportant: true },
      { id: 23, text: 'Jujutsu / One piece', isCompleted: false, isImportant: false }
    ]
  },
  {
    id: 3, startTime: '14', endTime: '16',
    tasks: [
      { id: 31, text: 'Autoescola', isCompleted: false, isImportant: false },
      { id: 32, text: 'Cortar cabelo', isCompleted: false, isImportant: false },
      { id: 33, text: 'Comprar whey', isCompleted: false, isImportant: false }
    ]
  },
  {
    id: 4, startTime: '16', endTime: '18',
    tasks: [
      { id: 41, text: 'Oficina', isCompleted: false, isImportant: false },
      { id: 42, text: 'Postar video', isCompleted: false, isImportant: false }
    ]
  },
  {
    id: 5, startTime: '18', endTime: '21',
    tasks: [
      { id: 51, text: 'Sair Júlia', isCompleted: false, isImportant: false }
    ]
  }
];

const initialNotes = [
  { id: 1, text: 'Comer bem' }
];

const initialDiary = {
  learned: '',
  improved: ''
};

export default function App() {
  const todayStr = getLocalDateString(new Date());

  // Estado principal da agenda
  const [agendaData, setAgendaData] = useState({
    [todayStr]: { blocks: initialBlocks, notes: initialNotes, diary: initialDiary }
  });

  const [currentDate, setCurrentDate] = useState(todayStr);

  const [newTaskText, setNewTaskText] = useState({});
  const [newBlockStart, setNewBlockStart] = useState('');
  const [newBlockEnd, setNewBlockEnd] = useState('');
  const [newNoteText, setNewNoteText] = useState('');

  // Limpar inputs ao mudar de data
  useEffect(() => {
    setNewTaskText({});
    setNewBlockStart('');
    setNewBlockEnd('');
    setNewNoteText('');
  }, [currentDate]);

  const currentDayData = agendaData[currentDate] || { blocks: [], notes: [], diary: { learned: '', improved: '' } };
  const blocks = currentDayData.blocks;
  const generalNotes = currentDayData.notes;
  const diary = currentDayData.diary || { learned: '', improved: '' };

  const setBlocks = (updater) => {
    setAgendaData(prev => {
      const dayData = prev[currentDate] || { blocks: [], notes: [] };
      const newBlocks = typeof updater === 'function' ? updater(dayData.blocks) : updater;
      return { ...prev, [currentDate]: { ...dayData, blocks: newBlocks } };
    });
  };

  const setGeneralNotes = (updater) => {
    setAgendaData(prev => {
      const dayData = prev[currentDate] || { blocks: [], notes: [] };
      const newNotes = typeof updater === 'function' ? updater(dayData.notes) : updater;
      return { ...prev, [currentDate]: { ...dayData, notes: newNotes } };
    });
  };

  // Funções de Navegação
  const changeDate = (offsetDays) => {
    const [year, month, day] = currentDate.split('-').map(Number);
    const date = new Date(year, month - 1, day);
    date.setDate(date.getDate() + offsetDays);
    setCurrentDate(getLocalDateString(date));
  };

  const goToToday = () => setCurrentDate(getLocalDateString(new Date()));

  const formatMonthYear = (dateStr) => {
    const [year, month, day] = dateStr.split('-').map(Number);
    const date = new Date(year, month - 1, day);
    return date.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
  };

  const formatFullDate = (dateStr) => {
    const [year, month, day] = dateStr.split('-').map(Number);
    const date = new Date(year, month - 1, day);
    return date.toLocaleDateString('pt-BR', { weekday: 'short', day: 'numeric', month: 'long' });
  };

  const weekDays = generateWeekDays(currentDate);

  // Funções de manipulação
  const toggleTaskCompletion = (blockId, taskId) => {
    setBlocks(blocks.map(block => {
      if (block.id === blockId) {
        return {
          ...block,
          tasks: block.tasks.map(task => 
            task.id === taskId ? { ...task, isCompleted: !task.isCompleted } : task
          )
        };
      }
      return block;
    }));
  };

  const toggleTaskImportance = (blockId, taskId) => {
    setBlocks(blocks.map(block => {
      if (block.id === blockId) {
        return {
          ...block,
          tasks: block.tasks.map(task => 
            task.id === taskId ? { ...task, isImportant: !task.isImportant } : task
          )
        };
      }
      return block;
    }));
  };

  const addTask = (blockId) => {
    const text = newTaskText[blockId];
    if (!text || text.trim() === '') return;

    setBlocks(blocks.map(block => {
      if (block.id === blockId) {
        return {
          ...block,
          tasks: [...block.tasks, { id: Date.now(), text, isCompleted: false, isImportant: false }]
        };
      }
      return block;
    }));
    setNewTaskText({ ...newTaskText, [blockId]: '' });
  };

  const addBlock = () => {
    if (!newBlockStart || !newBlockEnd) return;
    
    // Formata visualmente adicionando o zero à esquerda se o usuário digitar apenas "8"
    const formatTimeDisplay = (val) => {
      const num = parseInt(val.replace(/[^\d]/g, ''), 10);
      if (!isNaN(num) && num < 10 && val.length === 1) return `0${num}`;
      return val;
    };

    const newBlock = {
      id: Date.now(),
      startTime: formatTimeDisplay(newBlockStart),
      endTime: formatTimeDisplay(newBlockEnd),
      tasks: []
    };
    
    // ORDENAÇÃO CRONOLÓGICA REAL: Converte "08" ou "14:30" em minutos exatos e ordena
    const newBlocks = [...blocks, newBlock].sort((a, b) => {
       const startA = parseTimeToMinutes(a.startTime);
       const startB = parseTimeToMinutes(b.startTime);
       
       // Se os horários de início forem iguais, desempata pelo término
       if (startA === startB) {
         return parseTimeToMinutes(a.endTime) - parseTimeToMinutes(b.endTime);
       }
       return startA - startB;
    });

    setBlocks(newBlocks);
    setNewBlockStart('');
    setNewBlockEnd('');
  };

  const deleteBlock = (blockId) => {
    setBlocks(blocks.filter(block => block.id !== blockId));
  };

  const deleteTask = (blockId, taskId) => {
    setBlocks(blocks.map(block => {
      if (block.id === blockId) {
        return { ...block, tasks: block.tasks.filter(t => t.id !== taskId) };
      }
      return block;
    }));
  };

  const addNote = () => {
    if (!newNoteText.trim()) return;
    setGeneralNotes([...generalNotes, { id: Date.now(), text: newNoteText }]);
    setNewNoteText('');
  };

  const deleteNote = (noteId) => {
    setGeneralNotes(generalNotes.filter(n => n.id !== noteId));
  };

  const updateDiary = (field, value) => {
    setAgendaData(prev => {
      const dayData = prev[currentDate] || { blocks: [], notes: [], diary: { learned: '', improved: '' } };
      const currentDiary = dayData.diary || { learned: '', improved: '' };
      return {
        ...prev,
        [currentDate]: {
          ...dayData,
          diary: { ...currentDiary, [field]: value }
        }
      };
    });
  };

  return (
    <div className="min-h-screen bg-slate-100 text-slate-800 p-4 md:p-8 font-sans">
      <div className="max-w-2xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
        
        {/* Header da Agenda */}
        <div className="bg-indigo-600 text-white">
          <div className="p-6 pb-5">
            <div className="flex justify-between items-center mb-6">
              <h1 className="text-2xl font-bold flex items-center gap-2">
                <CalendarIcon className="w-6 h-6" />
                Minha Agenda
              </h1>
              {currentDate !== todayStr && (
                <button 
                  onClick={goToToday}
                  className="px-4 py-1.5 bg-indigo-500 hover:bg-indigo-400 rounded-full text-xs font-semibold transition-colors shadow-sm flex items-center gap-1"
                >
                  Ir para Hoje
                </button>
              )}
            </div>

            {/* Navegação Estilo Agenda (Semana) */}
            <div className="mb-3 flex items-center justify-between px-1">
              <button onClick={() => changeDate(-7)} className="p-1.5 hover:bg-indigo-500 rounded-lg transition-colors text-indigo-200 hover:text-white" title="Semana anterior">
                <ChevronLeft className="w-5 h-5" />
              </button>
              
              <div className="flex flex-col items-center relative group cursor-pointer">
                <span className="text-lg font-medium capitalize tracking-wide">
                  {formatMonthYear(currentDate)}
                </span>
                <input 
                  type="date" 
                  value={currentDate}
                  onChange={(e) => setCurrentDate(e.target.value)}
                  className="absolute inset-0 opacity-0 cursor-pointer"
                />
              </div>

              <button onClick={() => changeDate(7)} className="p-1.5 hover:bg-indigo-500 rounded-lg transition-colors text-indigo-200 hover:text-white" title="Próxima semana">
                <ChevronRight className="w-5 h-5" />
              </button>
            </div>

            {/* Carrossel de Dias */}
            <div className="flex justify-between items-center bg-indigo-700/40 rounded-2xl p-2 backdrop-blur-sm border border-indigo-500/30">
              {weekDays.map((day) => {
                const isSelected = day.dateStr === currentDate;
                const isToday = day.dateStr === todayStr;
                return (
                  <button
                    key={day.dateStr}
                    onClick={() => setCurrentDate(day.dateStr)}
                    className={`flex flex-col items-center justify-center w-11 h-14 md:w-14 md:h-16 rounded-xl transition-all duration-200 ${
                      isSelected 
                        ? 'bg-white text-indigo-600 shadow-lg transform scale-105' 
                        : 'text-indigo-100 hover:bg-indigo-500/60 hover:text-white'
                    } ${isToday && !isSelected ? 'ring-1 ring-indigo-300 ring-inset' : ''}`}
                  >
                    <span className={`text-xs md:text-sm font-medium capitalize ${isSelected ? 'text-indigo-500' : 'opacity-80'}`}>
                      {day.dayName}
                    </span>
                    <span className={`text-lg md:text-xl font-bold ${isSelected ? 'text-indigo-700' : ''}`}>
                      {day.dayNum}
                    </span>
                  </button>
                );
              })}
            </div>
          </div>
        </div>

        <div className="p-6">
          {blocks.length === 0 ? (
            <div className="text-center py-12 text-slate-400">
              <Clock className="w-12 h-12 mx-auto mb-3 opacity-20" />
              <p>Nenhum compromisso para este dia.</p>
              <p className="text-sm mt-1">Adicione um novo bloco de tempo abaixo.</p>
            </div>
          ) : (
            <div className="space-y-8">
              {blocks.map((block) => (
                <div key={block.id} className="relative flex gap-4 group">
                  {/* Linha vertical e horários */}
                  <div className="flex flex-col items-center w-14 shrink-0">
                    <span className="text-sm font-bold text-indigo-700">{block.startTime}h</span>
                    <div className="w-0.5 h-full bg-indigo-200 my-1 rounded-full relative">
                       <div className="absolute top-0 w-2 h-0.5 bg-indigo-400 -left-[3px]"></div>
                       <div className="absolute bottom-0 w-2 h-0.5 bg-indigo-400 -left-[3px]"></div>
                    </div>
                    <span className="text-sm font-bold text-indigo-700">{block.endTime}h</span>
                  </div>

                  {/* Área de Tarefas */}
                  <div className="flex-1 bg-slate-50 rounded-xl p-4 border border-slate-100 shadow-sm relative">
                    <button 
                      onClick={() => deleteBlock(block.id)}
                      className="absolute top-2 right-2 text-slate-300 hover:text-red-500 transition-colors md:opacity-0 md:group-hover:opacity-100"
                      title="Excluir bloco"
                    >
                      <Trash2 className="w-4 h-4" />
                    </button>

                    <ul className="space-y-3">
                      {block.tasks.map(task => (
                        <li key={task.id} className="flex items-start gap-3 group/task">
                          <button
                            onClick={() => toggleTaskCompletion(block.id, task.id)}
                            className={`mt-1 shrink-0 w-5 h-5 rounded border flex items-center justify-center transition-colors ${
                              task.isCompleted 
                                ? 'bg-indigo-500 border-indigo-500 text-white' 
                                : 'border-slate-300 hover:border-indigo-400 text-transparent hover:text-indigo-200'
                            }`}
                          >
                            <Check className="w-3.5 h-3.5" />
                          </button>
                          
                          <div className="flex-1 flex items-center flex-wrap gap-2">
                            <span 
                              className={`text-base transition-all ${
                                task.isCompleted ? 'line-through text-slate-400' : 'text-slate-700'
                              }`}
                            >
                              {task.text}
                            </span>
                            
                            {task.isImportant && (
                              <span className="inline-flex items-center gap-1 text-xs font-medium text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full border border-amber-200">
                                <AlertCircle className="w-3 h-3" />
                                Importante
                              </span>
                            )}
                          </div>

                          {/* Ações da tarefa */}
                          <div className="flex items-center gap-1 md:opacity-0 md:group-hover/task:opacity-100 transition-opacity">
                             <button 
                              onClick={() => toggleTaskImportance(block.id, task.id)}
                              className={`p-1 rounded ${task.isImportant ? 'text-amber-500' : 'text-slate-300 hover:text-amber-500'}`}
                              title="Marcar como importante"
                            >
                              <AlertCircle className="w-4 h-4" />
                            </button>
                            <button 
                              onClick={() => deleteTask(block.id, task.id)}
                              className="p-1 rounded text-slate-300 hover:text-red-500"
                              title="Excluir tarefa"
                            >
                              <Trash2 className="w-4 h-4" />
                            </button>
                          </div>
                        </li>
                      ))}
                    </ul>

                    {/* Input de nova tarefa */}
                    <div className="mt-4 flex gap-2">
                      <input
                        type="text"
                        placeholder="Adicionar tarefa..."
                        value={newTaskText[block.id] || ''}
                        onChange={(e) => setNewTaskText({ ...newTaskText, [block.id]: e.target.value })}
                        onKeyDown={(e) => e.key === 'Enter' && addTask(block.id)}
                        className="flex-1 text-sm bg-white border border-slate-200 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-500/50"
                      />
                      <button 
                        onClick={() => addTask(block.id)}
                        className="p-1.5 bg-indigo-100 text-indigo-700 rounded-lg hover:bg-indigo-200 transition-colors"
                      >
                        <Plus className="w-4 h-4" />
                      </button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* Adicionar Novo Bloco de Tempo */}
          <div className="mt-8 pt-6 border-t border-slate-200 flex flex-wrap gap-3 items-center">
            <span className="text-sm font-medium text-slate-600">Novo bloco:</span>
            <input 
              type="text" 
              placeholder="Início (ex: 08 ou 14:30)" 
              value={newBlockStart}
              onChange={e => setNewBlockStart(e.target.value)}
              className="w-32 text-sm bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500/50"
            />
            <span className="text-slate-400">-</span>
            <input 
              type="text" 
              placeholder="Fim (ex: 12 ou 16:00)" 
              value={newBlockEnd}
              onChange={e => setNewBlockEnd(e.target.value)}
              className="w-32 text-sm bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500/50"
            />
            <button 
              onClick={addBlock}
              className="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-1"
            >
              <Plus className="w-4 h-4" /> Bloco
            </button>
          </div>
        </div>

        {/* Seção de Notas Gerais */}
        <div className="bg-amber-50 p-6 border-t border-amber-100">
          <h2 className="text-lg font-semibold text-amber-900 flex items-center gap-2 mb-4">
            <FileText className="w-5 h-5" />
            Lembretes para {formatFullDate(currentDate).split(',')[0]}
          </h2>
          
          {generalNotes.length > 0 && (
            <ul className="space-y-2 mb-4">
              {generalNotes.map(note => (
                <li key={note.id} className="flex items-center gap-2 text-amber-800 bg-white/50 px-3 py-2 rounded-lg border border-amber-200 group">
                  <span className="w-1.5 h-1.5 rounded-full bg-amber-400 shrink-0"></span>
                  <span className="flex-1">{note.text}</span>
                  <button 
                    onClick={() => deleteNote(note.id)}
                    className="md:opacity-0 md:group-hover:opacity-100 p-1 text-amber-400 hover:text-red-500 transition-all"
                  >
                    <Trash2 className="w-4 h-4" />
                  </button>
                </li>
              ))}
            </ul>
          )}

          <div className="flex gap-2">
            <input
              type="text"
              placeholder="Adicionar um lembrete geral..."
              value={newNoteText}
              onChange={(e) => setNewNoteText(e.target.value)}
              onKeyDown={(e) => e.key === 'Enter' && addNote()}
              className="flex-1 text-sm bg-white border border-amber-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500/50"
            />
            <button 
              onClick={addNote}
              className="px-4 py-2 bg-amber-500 text-white text-sm font-medium rounded-lg hover:bg-amber-600 transition-colors"
            >
              Adicionar
            </button>
          </div>
        </div>

        {/* Diário de Performance */}
        <div className="bg-emerald-50 p-6 border-t border-emerald-100">
          <h2 className="text-lg font-semibold text-emerald-900 flex items-center gap-2 mb-4">
            <BookOpen className="w-5 h-5" />
            Diário de Performance
          </h2>

          <div className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-emerald-800 mb-2 flex items-center gap-1.5">
                <Lightbulb className="w-4 h-4 text-emerald-600" /> 
                1. O que eu aprendi hoje?
              </label>
              <textarea
                value={diary.learned}
                onChange={(e) => updateDiary('learned', e.target.value)}
                placeholder="Escreva seus aprendizados e reflexões positivas..."
                className="w-full text-sm bg-white border border-emerald-200 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 min-h-[80px] resize-y"
              />
            </div>

            <div>
              <label className="block text-sm font-medium text-emerald-800 mb-2 flex items-center gap-1.5">
                <Target className="w-4 h-4 text-emerald-600" /> 
                2. No que eu vacilei e poderia ter feito melhor?
              </label>
              <textarea
                value={diary.improved}
                onChange={(e) => updateDiary('improved', e.target.value)}
                placeholder="Escreva onde você falhou e como pode melhorar amanhã..."
                className="w-full text-sm bg-white border border-emerald-200 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 min-h-[80px] resize-y"
              />
            </div>
          </div>
        </div>

      </div>
    </div>
  );
}
